{
  "layer": "top",
  "positon": "top",
  "modules-left": ["niri/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory"],
  "clock": {
    "format": "{:%H:%M}"
  },
  "cpu": {
    "format": "{icon} {usage}",
    "format-icons": "<span rise='1200' size = '11000'>󰍛</span>",
		"states": {
			"warning": 75,
			"critical": 90
		}
  }
}
